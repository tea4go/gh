# ============================================================
# gh 项目测试环境变量模板
#
# 使用方法:
#   1. 复制本文件:  cp .env.example .env
#   2. 填入真实凭证值
#   3. 运行测试:    ./run_tests.sh
#
# 注意:
#   - .env 已加入 .gitignore，不会被提交到仓库
#   - 命令行设置的环境变量优先级高于 .env 文件
#   - 未配置的变量对应的测试会自动 Skip，不影响其他包
# ============================================================

# ─── 钉钉 ────────────────────────────────────────────────────
# 钉钉开放平台: https://open.dingtalk.com/
# 需要创建一个企业内部应用，获取 AppKey 和 AppSecret

# 企业内部应用凭证
DINGTALK_Client_ID=
DINGTALK_Client_Secret=
DINGTALK_Corp_ID=

# ─── 微信/企业微信 ───────────────────────────────────────────
# 企业微信管理后台: https://work.weixin.qq.com/

WEIXIN_Corp_ID=
WEIXIN_Corp_Secret=
WEIXIN_Agent_ID=

# ─── Redis ───────────────────────────────────────────────────
# 本地 Redis 服务地址，默认 localhost:6379

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── etcd ────────────────────────────────────────────────────
# 本地 etcd 服务地址，默认 localhost:2379

ETCD_ENDPOINTS=localhost:2379

# ─── LDAP ────────────────────────────────────────────────────
# 本地 LDAP/AD 服务器配置

LDAP_HOST=localhost
LDAP_PORT=389
LDAP_BIND_DN=
LDAP_BIND_PASS=
LDAP_BASE_DN=

# ─── 其他 ────────────────────────────────────────────────────
# CGO 编译（image 包需要，默认 1）
CGO_ENABLED=1

# HTTP 测试相关（可选）
GO_TEST_APPKEY=
GO_TEST_USER=
GO_TEST_PASS=
GO_TEST_LOGIN_URL=